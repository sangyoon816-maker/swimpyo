# Supabase (필수) — Supabase 프로젝트 > Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kakao Map JavaScript 키 (필수, /map 페이지) — Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
# 운영 배포 전 Kakao Developers 콘솔의 "플랫폼 > Web > 사이트 도메인"에 실제 배포 도메인을 등록해야 지도가 표시됩니다.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 운영 사이트 URL (선택) — 커스텀 도메인을 쓰는 경우에만 설정.
# 비워두면 Vercel이 자동 주입하는 VERCEL_PROJECT_PRODUCTION_URL을 사용하고,
# 그마저 없으면 http://localhost:3000으로 대체됩니다. (OG 이미지, sitemap.xml, robots.txt에 사용)
NEXT_PUBLIC_SITE_URL=
